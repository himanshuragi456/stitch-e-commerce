---
import '../styles/global.css';
import BaseHead from '../components/seo/BaseHead.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import OrderProofTicker from '../components/islands/OrderProofTicker';
import { api } from '../lib/api';
import type { Category, PublicSettings } from '../lib/types';

interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  type?: 'website' | 'product' | 'article';
  theme?: 'default' | 'emerald' | 'midnight' | 'terracotta';
}
const { title, description, image, noindex, type, theme = 'emerald' } = Astro.props;

// Fetched at build time; resilient if the API hiccups for non-catalog data.
let categories: Category[] = [];
let settings: PublicSettings | null = null;
try {
  [categories, settings] = await Promise.all([api.categories(), api.publicSettings()]);
} catch (err) {
  console.warn('[BaseLayout] failed to load chrome data:', (err as Error).message);
}
---

<!doctype html>
<html lang="en" data-theme={theme}>
  <head>
    <BaseHead title={title} description={description} image={image} noindex={noindex} type={type} />
    <slot name="head" />
  </head>
  <body class="flex min-h-screen flex-col">
    <Header categories={categories} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer categories={categories} settings={settings} />
    <OrderProofTicker client:idle />
  </body>
</html>
