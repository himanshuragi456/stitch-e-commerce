---
import Logo from './Logo.astro';
import type { Category, PublicSettings } from '../../lib/types';

interface Props {
  categories: Category[];
  settings: PublicSettings | null;
}
const { categories, settings } = Astro.props;
const year = new Date().getFullYear();
const social = settings?.social ?? {};
---

<footer class="mt-24 border-t border-[var(--color-border)] bg-[var(--color-surface)]">
  <div class="container-content grid gap-12 py-16 md:grid-cols-2 lg:grid-cols-4">
    <div class="max-w-xs">
      <Logo />
      <p class="mt-4 text-sm leading-relaxed text-[var(--color-ink-muted)]">
        Premium unstitched cloth, priced by the metre — ready to be stitched your way.
      </p>
    </div>

    <div>
      <h3 class="text-sm font-semibold tracking-wide text-[var(--color-ink)]">Shop</h3>
      <ul class="mt-4 space-y-2.5">
        {
          categories.slice(0, 5).map((c) => (
            <li>
              <a
                href={`/category/${c.slug}`}
                class="text-sm text-[var(--color-ink-muted)] transition-colors hover:text-[var(--color-primary)]"
              >
                {c.name}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <h3 class="text-sm font-semibold tracking-wide text-[var(--color-ink)]">Help</h3>
      <ul class="mt-4 space-y-2.5">
        {
          [
            ['About', '/about'],
            ['Contact', '/contact'],
            ['Shipping', '/policies/shipping'],
            ['Returns', '/policies/returns'],
          ].map(([label, href]) => (
            <li>
              <a
                href={href}
                class="text-sm text-[var(--color-ink-muted)] transition-colors hover:text-[var(--color-primary)]"
              >
                {label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <h3 class="text-sm font-semibold tracking-wide text-[var(--color-ink)]">Stay in touch</h3>
      {
        settings?.store?.phone && (
          <p class="mt-4 text-sm text-[var(--color-ink-muted)]">{settings.store.phone}</p>
        )
      }
      {
        settings?.store?.email && (
          <a
            href={`mailto:${settings.store.email}`}
            class="text-sm text-[var(--color-ink-muted)] transition-colors hover:text-[var(--color-primary)]"
          >
            {settings.store.email}
          </a>
        )
      }
      <div class="mt-4 flex gap-2">
        {
          social.instagram && (
            <a href={social.instagram} class="btn btn-ghost h-9 w-9 !p-0" aria-label="Instagram">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="20" x="2" y="2" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
            </a>
          )
        }
        {
          social.facebook && (
            <a href={social.facebook} class="btn btn-ghost h-9 w-9 !p-0" aria-label="Facebook">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
          )
        }
      </div>
    </div>
  </div>

  <div class="border-t border-[var(--color-border)]">
    <div
      class="container-content flex flex-col items-center justify-between gap-2 py-6 text-xs text-[var(--color-ink-muted)] sm:flex-row"
    >
      <p>© {year} Shree Krishna Collection. All rights reserved.</p>
      <div class="flex gap-4">
        <a href="/policies/privacy" class="transition-colors hover:text-[var(--color-primary)]">Privacy</a>
        <a href="/policies/terms" class="transition-colors hover:text-[var(--color-primary)]">Terms</a>
      </div>
    </div>
  </div>
</footer>
