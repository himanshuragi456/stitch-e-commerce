---
/**
 * This page requires a server adapter (prerender=false) to work as a dynamic route.
 * For the static build, redirect /account/orders/* to /account — order detail is
 * shown inline on the account page by island navigation.
 *
 * To enable this route with SSR, add an adapter (e.g. @astrojs/node) and set
 * `prerender = false` here.
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import OrderDetailIsland from '../../../components/islands/OrderDetailPage';

export function getStaticPaths() {
  return [];
}

const { id } = Astro.params;
---

<BaseLayout title="Order details — Shree Krishna Collection" noindex>
  <div class="container-content py-10 lg:py-16">
    <OrderDetailIsland orderId={id ?? ''} client:load />
  </div>
</BaseLayout>
