---
/**
 * Static build emits ONE shell at /account/orders/_/index.html (see
 * getStaticPaths below). The server rewrites any /account/orders/{id}
 * request to that shell (storefront/public/.htaccess), and the island reads
 * the real id from window.location client-side — Astro.params.id is not
 * available for arbitrary ids in a static build. Same pattern as
 * src/pages/order/[id]/confirmation.astro.
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import OrderDetailIsland from '../../../components/islands/OrderDetailPage';

export function getStaticPaths() {
  return [{ params: { id: '_' } }];
}
---

<BaseLayout title="Order details — Shree Krishna Collection" noindex>
  <div class="container-content py-10 lg:py-16">
    <OrderDetailIsland client:load />
  </div>
</BaseLayout>
