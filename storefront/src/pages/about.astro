---
import BaseLayout from '../layouts/BaseLayout.astro';
import { STORY_IMAGE } from '../lib/images';

const values = [
  {
    title: 'Curated, not endless',
    body: 'Every bolt is chosen by hand. We stock fabrics we would happily stitch for ourselves — no filler, no compromise.',
  },
  {
    title: 'Honest per-metre pricing',
    body: 'You pay for exactly the length you need. No hidden minimums, no inflated MRPs — just fair pricing on genuine cloth.',
  },
  {
    title: 'Straight from the mills',
    body: 'We work directly with India’s and Italy’s finest mills, so the same cloth that fills premium tailoring houses reaches you.',
  },
];
---

<BaseLayout
  title="Our story — Shree Krishna Collection"
  description="Three generations in textiles, now a few taps away. Learn about Shree Krishna Collection and how we bring premium unstitched fabric to your door."
>
  <!-- Intro -->
  <section class="container-content py-14 lg:py-20">
    <div class="mx-auto max-w-2xl text-center">
      <span class="text-xs font-medium uppercase tracking-[0.22em] text-[var(--color-accent)]">Our story</span>
      <h1 class="mt-3 font-[var(--font-heading)] text-3xl leading-tight sm:text-4xl lg:text-5xl">
        A textile family, three generations deep.
      </h1>
      <p class="mt-5 text-base leading-relaxed text-[var(--color-ink-muted)]">
        Shree Krishna Collection began at a fabric counter and grew into a promise: bring the
        same cloth that fills the finest tailoring houses to anyone who cares how their clothes
        are made. Today that counter lives online — but the eye for quality hasn't changed.
      </p>
    </div>
  </section>

  <!-- Image + copy -->
  <section class="container-content pb-16">
    <div class="grid items-stretch gap-8 overflow-hidden rounded-[var(--radius-lg)] border border-[var(--color-border)] lg:grid-cols-2">
      <div class="relative min-h-[320px]">
        <img
          src={STORY_IMAGE}
          alt="Selecting fabric at Shree Krishna Collection"
          width="1000"
          height="1200"
          loading="lazy"
          decoding="async"
          class="absolute inset-0 h-full w-full object-cover"
        />
      </div>
      <div class="flex flex-col justify-center bg-[var(--color-surface)] p-8 lg:p-14">
        <h2 class="text-2xl leading-snug sm:text-3xl">Cloth, chosen with care.</h2>
        <p class="mt-4 text-[0.95rem] leading-relaxed text-[var(--color-ink-muted)]">
          We measure twice, fold with care, and send you unstitched fabric that's ready to become
          exactly what you imagine. Buy it by the metre, hand it to your tailor, and wear something
          truly yours.
        </p>
        <div class="mt-7">
          <a href="/category/shirting" class="btn btn-primary">Shop the collection</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="border-t border-[var(--color-border)] bg-[var(--color-surface)]">
    <div class="container-content py-16">
      <div class="grid gap-8 sm:grid-cols-3">
        {
          values.map((v) => (
            <div class="flex flex-col items-center text-center sm:items-start sm:text-left">
              <h3 class="text-base font-medium text-[var(--color-ink)]">{v.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-[var(--color-ink-muted)]">{v.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
